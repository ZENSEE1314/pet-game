# ---------------------------------------------------------------------------
# PetQuest Rewards — environment variables
# Copy to `.env` and fill in:   cp env.example .env
# Every variable here is validated at boot by src/lib/env.ts; the app refuses
# to start if a required one is missing or too weak.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
DATABASE_URL="postgresql://petquest:petquest@localhost:5432/petquest?schema=public"

# --- Redis ------------------------------------------------------------------
# Cooldowns, rate limits and leaderboard caching. The app degrades gracefully to
# a Postgres-only path if Redis is unreachable, but you want it in production.
REDIS_URL="redis://localhost:6379"

# --- Auth.js / NextAuth -----------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-auth-secret-change-me-0123456789abcd"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional in development — leave blank to hide the Google button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Signing keys -----------------------------------------------------------
# HMAC key for signed mini-game sessions. Must NEVER reach the browser.
GAME_SESSION_SECRET="dev-only-game-session-secret-change-me-0123456789"
# HMAC key for signed reward-claim QR tokens. Must NEVER reach the browser.
QR_TOKEN_SECRET="dev-only-qr-token-secret-change-me-0123456789abcd"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PetQuest Rewards"
DEFAULT_TIMEZONE="Asia/Kuala_Lumpur"

# --- Email (stubbed in the MVP: tokens are logged to the server console) -----
EMAIL_FROM="PetQuest <no-reply@petquest.local>"
