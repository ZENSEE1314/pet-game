// PetQuest Rewards — data model
//
// Invariants encoded here that the application MUST NOT violate:
//   * CurrencyTransaction is append-only. There is no update path in the codebase.
//   * CurrencyBalance is a cached projection of the ledger, written only by the
//     transaction service, only inside a DB transaction, only alongside a ledger row.
//   * idempotencyKey is globally unique — that unique index IS the double-spend guard.
//   * Money is Int. Never Float, never Decimal-with-fractional-cents. Whole units only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  PLAYER
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum PermissionKey {
  ADJUST_BALANCE
  MANAGE_USERS
  MANAGE_REWARDS
  MANAGE_MISSIONS
  MANAGE_GAMES
  MANAGE_ITEMS
  APPROVE_CLAIMS
  SCAN_CLAIMS
  VIEW_ANALYTICS
  VIEW_AUDIT_LOG
  MANAGE_ROLES
  MANAGE_SETTINGS
  REVIEW_FRAUD
  SEND_ANNOUNCEMENTS
  MANAGE_PROMO_CODES
}

enum CurrencyType {
  COINS
  REWARD_POINTS
  GEMS
}

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum TransactionCategory {
  PET_CARE
  DAILY_CARE_BONUS
  GAME_REWARD
  MISSION_REWARD
  ACHIEVEMENT_REWARD
  LOGIN_STREAK
  REFERRAL_REWARD
  PROMO_CODE
  EVENT_REWARD
  LEADERBOARD_PRIZE
  ITEM_PURCHASE
  REWARD_REDEMPTION
  REWARD_REFUND
  ADMIN_ADJUSTMENT
  SIGNUP_BONUS
  GAME_ENERGY_REFILL
}

enum PetStage {
  EGG
  BABY
  YOUNG
  ADULT
  EVOLVED
}

enum PetHealthState {
  HEALTHY
  TIRED
  SICK
}

enum PetCareAction {
  FEED
  BATHE
  PLAY
  SLEEP
  MEDICINE
}

enum ItemCategory {
  FOOD
  MEDICINE
  CLOTHING
  DECORATION
  GAME_TICKET
  EVOLUTION_ITEM
  EVENT_ITEM
  COLLECTIBLE
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum AcquisitionSource {
  SHOP_PURCHASE
  MISSION_REWARD
  ACHIEVEMENT_REWARD
  PROMO_CODE
  ADMIN_GRANT
  EVENT
  STARTER_PACK
}

enum GameSlug {
  ENDLESS_RUNNER
  FEEDING_CATCH
}

enum GameSessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  REJECTED
}

enum MissionType {
  DAILY_LOGIN
  FEED_PET
  BATHE_PET
  PLAY_WITH_PET
  COMPLETE_DAILY_CARE
  PLAY_MINI_GAME
  PLAY_GAME_COUNT
  REACH_SCORE
  EARN_COINS
  VISIT_REWARD_SHOP
  REDEEM_REWARD
  LOGIN_STREAK
  USE_ITEM
  ENTER_PROMO_CODE
}

enum MissionFrequency {
  DAILY
  WEEKLY
  ONE_TIME
}

enum RewardType {
  COINS
  REWARD_POINTS
  GEMS
  ITEM
  BADGE
  TITLE
  XP
}

enum UserMissionStatus {
  IN_PROGRESS
  COMPLETED
  CLAIMED
  EXPIRED
}

enum AchievementCode {
  ADOPT_FIRST_PET
  FIRST_CARE_ACTION
  SEVEN_DAY_STREAK
  FEED_100_TIMES
  PLAY_100_GAMES
  REACH_LEVEL_10
  EARN_10000_COINS
  FIRST_REDEMPTION
  TOP_100_LEADERBOARD
  EVOLVE_PET
}

enum RewardCategory {
  DIGITAL_VOUCHER
  DISCOUNT_COUPON
  FOOD_AND_DRINK
  TOY
  MERCHANDISE
  FREE_GAME_ATTEMPT
  EVENT_TICKET
  LIMITED_EDITION
}

enum CollectionMethod {
  DIGITAL_CODE
